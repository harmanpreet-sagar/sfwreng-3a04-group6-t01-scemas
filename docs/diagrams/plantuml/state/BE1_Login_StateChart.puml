@startuml BE1_Logins_StateChart
hide empty description

state "DisplayLoginPage\n----\nusernameInput\npasswordInput\nloginPageVisible = true" as displayLoginPage : display login screen

state "VerifyCredentials\n----\nusernameInput\npasswordInput\ncredentialsValid" as verifyCredentials : verify credentials

state "LoginError\n----\nerrorMessage" as loginError : display error message

state "ClassifyRole\n----\nuserRole\nadditionalVerificationRequired" as classifyRole : classify user role

state "RequestAdditionalVerification\n----\nverificationStatus" as requestAdditionalVerification : request extra verification

state "GrantAccess\n----\nsessionToken\nassignedPermissions" as grantAccess : grant access based on RBAC permissions

state "RedirectDashboard\n----\ndashboardType" as redirectDashboard : redirect to correct dashboard

state "RecordLoginEvent\n----\nloginTimestamp\nauditEntry" as recordLoginEvent : record login event in audit logs

[*] --> displayLoginPage

displayLoginPage --> verifyCredentials : credentials entered

verifyCredentials --> loginError : invalid credentials
loginError --> displayLoginPage : retry

verifyCredentials --> classifyRole : valid credentials

classifyRole --> requestAdditionalVerification : role has additional permissions
requestAdditionalVerification --> loginError : verification failed
requestAdditionalVerification --> grantAccess : verification succeeded

classifyRole --> grantAccess : standard role

grantAccess --> redirectDashboard
redirectDashboard --> recordLoginEvent
recordLoginEvent --> [*]

@enduml