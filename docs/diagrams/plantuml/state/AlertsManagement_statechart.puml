@startuml AlertsManagement_StateChart
hide empty description
top to bottom direction

state "Monitoring\n----\nvalidatedReadings\naggregatedData\nactiveThresholds\nstatusChangeRequest\n----\nwait for validated data, aggregated data, or alert status updates" as Monitoring

state "EvaluateThresholdViolations\n----\nvalidatedReadings\nactiveThresholds\nthresholdViolationDetected\n----\ncompare validated readings against active thresholds" as EvaluateThresholdViolations

state "DetectAnomalousTrends\n----\naggregatedData\nanomalyDetected\n----\nanalyze aggregated environmental data for anomalous trends" as DetectAnomalousTrends

state "CreateAlert\n----\nalertDetails\nsourceType\nalertStatus\n----\ncreate alert and store it in AlertsDB" as CreateAlert

state "UpdateAlertStatus\n----\nalertId\nnewStatus\nupdatedAt\n----\nupdate alert status in AlertsDB" as UpdateAlertStatus

state "PublishAlertUpdate\n----\nalert\nnotificationPayload\n----\npublish alert update and notify dashboard" as PublishAlertUpdate

state "AlertError\n----\nfailedOperation\nerrorMessage\n----\nrecord failure and preserve monitoring flow" as AlertError

[*] --> Monitoring

Monitoring --> EvaluateThresholdViolations : validated sensor data received
EvaluateThresholdViolations --> CreateAlert : threshold violation detected
EvaluateThresholdViolations --> Monitoring : no threshold violation

Monitoring --> DetectAnomalousTrends : aggregated data received
DetectAnomalousTrends --> CreateAlert : anomalous trend detected
DetectAnomalousTrends --> Monitoring : no anomalous trend

CreateAlert --> PublishAlertUpdate : alert stored successfully
CreateAlert --> AlertError : alert creation fails

Monitoring --> UpdateAlertStatus : acknowledge request received
UpdateAlertStatus --> PublishAlertUpdate : status updated
UpdateAlertStatus --> AlertError : status update fails

PublishAlertUpdate --> Monitoring : update published
PublishAlertUpdate --> AlertError : notification fails
PublishAlertUpdate--> [*] : notification succeeds

AlertError --> Monitoring : retry

@enduml