@startuml BE4_CreateAccount_StateChart
hide empty description

state "DisplayCreateAccountPage\n----\nrequestedRole\naccountData" as displayCreateAccountPage : display relevant account creation page

state "ValidateInputs\n----\naccountData\nrequiredFieldsFilled\nvalidInput\nvalidationErrors" as validateInputs : validate account information

state "AccountError\n----\nerrorMessage" as accountError : display error message

state "CheckRoleRequirements\n----\nrequestedRole\nverificationRequired" as checkRoleRequirements : determine requested role requirements

state "RequestVerification\n----\nverificationRequest\nverificationStatus" as requestVerification : send request for verification

state "RecordFailureEvent\n----\nfailureReason\nauditEntry" as recordFailureEvent : record failure in audit logs

state "CreateAccount\n----\naccountData\nassignedPermissions\naccountCreationStatus" as createAccount : create account with role and RBAC permissions

state "ConfirmAccountCreation\n----\naccountId\nconfirmationMessage" as confirmAccountCreation : confirm account creation and prompt Log In

state "RecordAccountCreationEvent\n----\naccountId\ncreationTimestamp\nauditEntry" as recordAccountCreationEvent : record account creation event in audit logs

[*] --> displayCreateAccountPage

displayCreateAccountPage --> validateInputs : required information entered

validateInputs --> accountError : information is missing or invalid
accountError --> displayCreateAccountPage : retry

validateInputs --> checkRoleRequirements : inputs valid

checkRoleRequirements --> requestVerification : role requires verification
requestVerification --> recordFailureEvent : verification fails
recordFailureEvent --> accountError : notify user

requestVerification --> createAccount : verification succeeds
checkRoleRequirements --> createAccount : no verification required

createAccount --> recordFailureEvent : account creation fails
createAccount --> confirmAccountCreation : account created

confirmAccountCreation --> recordAccountCreationEvent
recordAccountCreationEvent --> [*]

@enduml