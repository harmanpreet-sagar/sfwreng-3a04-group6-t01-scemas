@startuml

' ========================
' Single Interface
' ========================

interface IValidationComponent {
  + execute(): void
}

' ========================
' Classes
' ========================

class DataValidationManagement {
  + validateIncomingData(): void
  + coordinateValidation(): void
}

class EnsureMQTTCompliance {
  + parsePacket(): boolean
  + validateMQTTFormat(): boolean
}

class SensorMonitor {
  + monitorSensorData(): void
  + detectAnomalies(): boolean
}

class StoreValidatedData {
  + storeData(): void
  + sendToTimeSeriesDB(): void
}

class ValidationEventLog {
  + logEvent(e : EventLog): void
  + attachTimestamp(e : EventLog): void
  + formatLog(e : EventLog): String
}

class ValidSensorDataDB {
  + store(): void
  + retrieveHistoricalData(): List
}

' ========================
' NEW ENTITY
' ========================

entity EventLog {
  -eventId : int
  -eventType : String
  -message : String
  -source : String
  -timestamp : DateTime
  -status : String
  
  +createLog(eventType : String, message : String, source : String) : EventLog
  +updateStatus(status : String)
  +getDetails() : Map
}

' ========================
' Interface Implementation
' ========================

IValidationComponent <|.. EnsureMQTTCompliance
IValidationComponent <|.. SensorMonitor
IValidationComponent <|.. StoreValidatedData

' ========================
' Controller depends on interface
' ========================

DataValidationManagement --> IValidationComponent : uses / depends on

' ========================
' Relationships
' ========================

EnsureMQTTCompliance --> ValidationEventLog
SensorMonitor --> ValidSensorDataDB
StoreValidatedData --> ValidSensorDataDB

' NEW relationships for EventLog
ValidationEventLog --> EventLog : creates / formats

@enduml