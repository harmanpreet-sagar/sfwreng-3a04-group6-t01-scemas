@startuml SCEMAS_SystemClassDiagram
scale 0.4

skinparam nodesep 50
skinparam ranksep 70

' Legend for change markers:
'   #FFD0D0 background = new class (did not exist in original)
'   ##[bold]red border = existing class whose fields or methods changed
'   -[#red,bold]->     = new relationship (did not exist in original)
' Classes that only received a stereotype label are NOT marked red.

' =============================================================
' SHARED TYPES
' =============================================================
class Request {
  -endpoint : String
  -userId : String
  -role : String
  -payload : Map
  -timestamp : DateTime
  -apiKey : String
}

class Result {
  -success : Boolean
  -data : Map
  -errorMessage : String
  -statusCode : int
  -timestamp : DateTime
}

class Response {
  -statusCode : int
  -body : Map
  -message : String
  -timestamp : DateTime
}

class successResponse {
  -result : Result
  -resp : Response
  +formatAndReturnSuccessResponse()
}

class errorResponse {
  -statusCode : int
  -resp : Response
  +formatAndReturnErrorResponse()
}

entity Alert {
  -alertId : String
  -severity : String
  -message : String
  -status : String
  -createdAt : DateTime
  -updatedAt : DateTime
  -zone : String
  -metric : String
  -sourceType : String
}

enum AlertStatus {
  ACTIVE
  ACKNOWLEDGED
  RESOLVED
}

successResponse ..> Result
successResponse ..> Response
errorResponse   ..> Response
Alert           --> AlertStatus

' =============================================================
' PACKAGE: PRESENTATION LAYER (PAC)
'
' PAC triad for the top-level SCEMAS agent:
'   P (Presentation) — *Agent boundary classes
'   A (Abstraction)  — RecentActivityCache  [NEW]
'   C (Control)      — APIFacade
' =============================================================
package "Presentation Layer (PAC)" {

  ' Unchanged content — stereotype label only added, not red
  class AccountAdminAgent <<Presentation>> {
    +initiateAccountOperation(req : Request)
  }

  class ThresholdAdminAgent <<Presentation>> {
    +initiateThresholdOperation(req : Request)
  }

  class DashboardAgent <<Presentation>> {
    +displayData(data : Map)
    +displayAlert(alert : Alert)
    +displayAlerts()
    +refreshView()
  }

  ' NEW — was missing from original diagram despite being present
  ' in the D2 architecture diagram as "Recent Activity Cache".
  ' Holds UI-visible state so no Presentation class ever queries
  ' a backend subsystem directly.
  ' Maps to AuthContext + local React state in the frontend.
  class RecentActivityCache <<Abstraction>> #FFD0D0 {
    -cachedAlerts : List
    -cachedThresholds : List
    -lastUpdated : DateTime
    +getAlerts() : List
    +getThresholds() : List
    +updateAlerts(alerts : List)
    +updateThresholds(thresholds : List)
    +invalidate()
  }

  ' Unchanged content — stereotype label only added, not red
  class APIFacade <<Control>> {
    -req : Request
    -result : Result
    -resp : Response
    +apiRequest(req : Request)
    +validateRequest(req : Request) : Boolean
    +authorizeRequest(req : Request) : Boolean
    +dispatchRequest(req : Request) : Result
    +formatResponse(result : Result) : Response
    +returnResponse(resp : Response)
  }

  interface IThresholdService {
    -action : String
    -data : Map
    +receiveRequest(action : String)
    +validateInput(data : Map) : Boolean
    +processAction(action : String, data : Map)
  }

  interface IAccountService {
    -credentials : Map
    -data : Map
    +login(credentials : Map) : Boolean
    +changeCredentials(data : Map)
    +deactivateAccount(id : int)
  }

  interface IAlertsService {
    -data : Map
    -violation : Map
    +generateAlert(violation : Map) : Alert
    +updateAlertStatus(id : int, status : String)
  }

  interface IAggregationService {
    -data : Map
    +performAggregations()
    +showDataToDashboards(data : Map)
  }

  AccountAdminAgent   --> APIFacade
  ThresholdAdminAgent --> APIFacade
  DashboardAgent      --> APIFacade

  ' NEW — completing the PAC C<->A and A->P wiring
  APIFacade           -[#red,bold]-> RecentActivityCache
  RecentActivityCache -[#red,bold]-> DashboardAgent

  APIFacade --> IThresholdService
  APIFacade --> IAccountService
  APIFacade --> IAlertsService
  APIFacade --> IAggregationService

  APIFacade           ..> Request
  APIFacade           ..> Result
  APIFacade           ..> Response
  APIFacade           ..> successResponse
  APIFacade           ..> errorResponse
  AccountAdminAgent   ..> Request
  ThresholdAdminAgent ..> Request
  DashboardAgent      ..> Alert
  IAlertsService      ..> Alert
  RecentActivityCache ..> Alert
}

' =============================================================
' PACKAGE: ACCOUNT MANAGEMENT
' =============================================================
package "Account Management" {

  class AccountManagement {
    -credentials : Map
    -data : Map
    +receiveRequest(action : String)
    +validateInput(data : Map) : Boolean
    +processAction(action : String, data : Map)
    +validateUser() : Boolean
    +login(credentials : Map) : Boolean
    +changeCredentials(data : Map)
    +deactivateAccount(id : int)
  }

  class Logins {
    +parseInput(data : Map) : Map
    +checkAccountExists() : Boolean
    +tryPassword() : Boolean
    +acceptLoginAttempt() : Boolean
    +createAccount(data : Map)
  }

  class ChangeUserPass {
    +editPassword()
    +confirmChanges() : Boolean
    +writeToDB(aid : int) : Boolean
  }

  class DeactivateAccount {
    +confirmDeactivation()
    +deactivateAccount(a : Account)
    +updateRepository(aid : int)
  }

  interface AccountRepository {
    +create(t : Account)
    +update(t : Account)
    +delete(id : int)
    +deleteInactive()
    +findById(id : int) : Account
    +findAll() : List
  }

  entity AccountDB {
    +create(t : Account)
    +update(t : Account)
    +delete(id : int)
    +deleteInactive()
    +findById(id : int) : Account
    +findAll() : List
  }

  ' MODIFIED — removed age and address: neither field exists in
  ' 019_create_accounts.sql, AccountResponse, or any Pydantic model.
  entity Account ##[bold]red {
    -aid : int
    -name : String
    -email : String
    -password : String
    -clearance : String
    -isActive : Boolean
    -createdAt : DateTime
    -updatedAt : DateTime
    +deactivate() : Boolean
    +decrypt(password : String, aid : int) : String
    +encrypt(aid : int)
    +getDetails() : List
  }

  AccountManagement  --> Logins
  AccountManagement  --> ChangeUserPass
  AccountManagement  --> DeactivateAccount
  Logins             ..> AccountRepository
  ChangeUserPass     ..> AccountRepository
  DeactivateAccount  ..> AccountRepository
  AccountDB          ..|> AccountRepository
  AccountDB          *-- Account
}

' =============================================================
' PACKAGE: THRESHOLD MANAGEMENT
' =============================================================
package "Threshold Management" {

  class ThresholdManagement {
    -action : String
    -data : Map
    +receiveRequest(action : String)
    +validateInput(data : Map) : Boolean
    +processAction(action : String, data : Map)
  }

  class HighLevelUI {
    -thresholdList : List
    +displayThresholds()
    +displayForm()
    +displayConfirmation()
    +displayError(msg : String)
  }

  class CreateThreshold {
    -metricType : String
    -zone : String
    -condition : String
    -severityLevel : String
    +inputThresholdData() : Map
    +validateData(data : Map) : Boolean
    +createThreshold(data : Map) : Threshold
    +saveThreshold(t : Threshold)
  }

  class EditThreshold {
    -id : int
    -threshold : Threshold
    -changes : Map
    +loadThreshold(id : int) : Threshold
    +editThreshold(t : Threshold, changes : Map)
    +validateChanges(changes : Map) : Boolean
    +saveThreshold(t : Threshold)
  }

  class DeleteThreshold {
    -id : int
    -threshold : Threshold
    -confirmed : Boolean
    +receiveDeleteRequest(id : int)
    +retrieveThreshold(id : int) : Threshold
    +deleteThreshold(t : Threshold)
    +updateRepository(id : int)
  }

  interface IThresholdRepository {
    +save(t : Threshold)
    +update(t : Threshold)
    +delete(id : int)
    +findById(id : int) : Threshold
    +findAll() : List
    +findActive() : List
  }

  entity ThresholdDB {
    -threshold : Threshold
    +save(t : Threshold)
    +update(t : Threshold)
    +delete(id : int)
    +findById(id : int) : Threshold
    +findAll() : List
    +findActive() : List
    +getActiveThresholdRules() : List
  }

  entity Threshold {
    -id : int
    -metricType : String
    -zone : String
    -condition : String
    -severityLevel : String
    -isActive : Boolean
    -createdAt : DateTime
    -updatedAt : DateTime
    +activate()
    +deactivate()
    +getDetails() : Map
  }

  HighLevelUI         --> ThresholdManagement
  ThresholdManagement --> CreateThreshold
  ThresholdManagement --> EditThreshold
  ThresholdManagement --> DeleteThreshold
  CreateThreshold     ..> IThresholdRepository
  EditThreshold       ..> IThresholdRepository
  DeleteThreshold     ..> IThresholdRepository
  ThresholdDB         ..|> IThresholdRepository
  ThresholdDB         *-- Threshold
}

' =============================================================
' PACKAGE: ALERTS MANAGEMENT
' =============================================================
package "Alerts Management" {

  ' NEW — replaces the direct arrow AlertsManagement -> ThresholdDB.
  ' ThresholdEvaluatorWorker depends on this interface only;
  ' the concrete ThresholdDB lives in Threshold Management.
  class IThresholdRepository <<external>> #FFD0D0 {
    +getActiveThresholdRules() : List
  }

  ' NEW — replaces the direct arrow AlertsManagement -> AggregatedEnvironmentalDataDB.
  class IAggregatedDataRepository <<external>> #FFD0D0 {
    +getAggregatedEnvironmentalData(zoneId : String, metric : String) : List
  }

  ' NEW — maps to threshold_evaluator_worker.py + threshold_evaluation.py.
  ' Background asyncio task that polls every 5 s, checks the latest
  ' aggregated value per zone/metric against every active threshold,
  ' and calls AlertsManagement.createAlert() on breach.
  ' Absorbs evaluateThresholdViolations() and detectAnomalousTrends()
  ' that were incorrectly placed on AlertsManagement in the original.
  class ThresholdEvaluatorWorker #FFD0D0 {
    -intervalSeconds : int
    +runEvaluationCycle()
    +isThresholdBreached(condition : String, observed : float, limit : float) : Boolean
  }

  ' NEW — maps to alert_sse_broadcaster.py (AlertSSEBroadcaster class).
  ' Thread-safe in-memory fan-out; publishes alert.created /
  ' alert.acknowledged / alert.resolved events to all connected
  ' dashboard SSE clients without coupling AlertsManagement to
  ' DashboardAgent directly.
  class AlertSSEBroadcaster #FFD0D0 {
    -subscriberQueues : Set
    +subscribe() : Queue
    +unsubscribe(q : Queue)
    +publish(event : Map)
    +stream(request : Request)
  }

  ' MODIFIED — methods realigned with AlertService in alert_service.py.
  ' Removed: evaluateTelemetry, generateAlert, evaluateThresholdViolations,
  '          detectAnomalousTrends (these belong to ThresholdEvaluatorWorker)
  ' Added:   acknowledgeAlert, resolveAlert, listAlerts, getAlertById,
  '          activeAlertExistsForZoneMetric (all in AlertService)
  class AlertsManagement ##[bold]red {
    -data : Map
    +createAlert(alert : Alert)
    +acknowledgeAlert(id : int)
    +resolveAlert(id : int)
    +listAlerts(status : String, zone : String, severity : String) : List
    +getAlertById(id : int) : Alert
    +activeAlertExistsForZoneMetric(zone : String, metric : String) : Boolean
    +publishAlertUpdate(alert : Alert)
  }

  ' MODIFIED — sendStatusChangeNotification() removed: it does not
  ' exist in notification_service.py. Only
  ' send_critical_alert_sms_if_configured() exists (Twilio, critical only).
  class NotificationService ##[bold]red {
    +sendCriticalAlertSms(alert : Alert)
  }

  entity AlertsDB {
    +storeAlert(alert : Alert)
    +updateAlert(alert : Alert)
    +getActiveAlerts() : List
    +getHistoricalAlerts() : List
  }

  ' NEW relationships
  AlertsManagement -[#red,bold]-> AlertSSEBroadcaster
  AlertsManagement               --> AlertsDB
  AlertsManagement               --> NotificationService

  ThresholdEvaluatorWorker -[#red,bold]-> IThresholdRepository
  ThresholdEvaluatorWorker -[#red,bold]-> IAggregatedDataRepository
  ThresholdEvaluatorWorker -[#red,bold]-> AlertsManagement

  AlertsDB            --> Alert
  NotificationService ..> Alert
  AlertSSEBroadcaster ..> Alert
}

' =============================================================
' PACKAGE: DATA VALIDATION
' =============================================================
package "Data Validation" {

  ' NEW — maps to mqtt_subscriber.py.
  ' Connects to Mosquitto over TLS, subscribes to scemas/sensors/#,
  ' and hands each decoded JSON payload to DataValidationManagement.
  class MqttSubscriber #FFD0D0 {
    -host : String
    -port : int
    -topic : String
    +connect()
    +onConnect()
    +onMessage(msg : Map)
    +onDisconnect()
  }

  interface IValidationComponent {
    +execute()
  }

  class DataValidationManagement {
    +validateIncomingData()
    +coordinateValidation()
  }

  class EnsureMQTTCompliance {
    +parsePacket() : Boolean
    +validateMQTTFormat() : Boolean
  }

  class SensorMonitor {
    +monitorSensorData()
    +detectAnomalies() : Boolean
  }

  class StoreValidatedData {
    +storeData()
    +sendToTimeSeriesDB()
  }

  class ValidationEventLog {
    +logEvent(e : EventLog)
    +attachTimestamp(e : EventLog)
    +formatLog(e : EventLog) : String
  }

  entity ValidSensorDataDB {
    +store()
    +retrieveHistoricalData() : List
    +getValidatedSensorData() : List
  }

  entity EventLog {
    -eventId : int
    -eventType : String
    -message : String
    -source : String
    -timestamp : DateTime
    -status : String
    +createLog(eventType : String, message : String, source : String) : EventLog
    +updateStatus(status : String)
    +getDetails() : Map
  }

  ' NEW relationship
  MqttSubscriber           -[#red,bold]-> DataValidationManagement
  IValidationComponent     <|.. EnsureMQTTCompliance
  IValidationComponent     <|.. SensorMonitor
  IValidationComponent     <|.. StoreValidatedData
  DataValidationManagement --> IValidationComponent
  EnsureMQTTCompliance     --> ValidationEventLog
  SensorMonitor            --> ValidSensorDataDB
  StoreValidatedData       --> ValidSensorDataDB
  ValidationEventLog       --> EventLog
}

' =============================================================
' PACKAGE: AGGREGATION MANAGEMENT
' =============================================================
package "Aggregation Management" {

  class AggregationManagement {
    -data : Map
    +performAggregations()
    +showDataToDashboards(data : Map)
  }

  class PerformAggregations {
    -zone : String
    -interval : String
    -metricType : String
    +computeAggregatedMetrics(data : Map) : AggregatedData
    +saveResult(d : AggregatedData)
  }

  class ShowDataToDashboards {
    -zone : String
    +fetchAggregatedData(zone : String) : List
    +sendDataToDashboard(data : Map)
  }

  interface IAggregatedDataRepository {
    +save(d : AggregatedData)
    +findByZone(zone : String) : List
    +findByInterval(interval : String) : List
    +findLatest(zone : String) : AggregatedData
  }

  entity AggregatedEnvironmentalDataDB {
    -aggregatedData : AggregatedData
    +save(d : AggregatedData)
    +findByZone(zone : String) : List
    +findByInterval(interval : String) : List
    +findLatest(zone : String) : AggregatedData
    +getAggregatedEnvironmentalData(zoneId : String, metric : String) : List
  }

  entity AggregatedData {
    -id : int
    -zone : String
    -metricType : String
    -value : double
    -interval : String
    -timestamp : DateTime
    +getSummary() : Map
  }

  AggregationManagement         --> PerformAggregations
  AggregationManagement         --> ShowDataToDashboards
  PerformAggregations           ..> IAggregatedDataRepository
  ShowDataToDashboards          ..> IAggregatedDataRepository
  AggregatedEnvironmentalDataDB ..|> IAggregatedDataRepository
  AggregatedEnvironmentalDataDB *-- AggregatedData
  PerformAggregations           ..> AggregatedData
  IAggregatedDataRepository     ..> AggregatedData
}

' =============================================================
' PACKAGE: API MANAGEMENT
' =============================================================
package "API Management" {

  class APIManagement {
    +processReadOnlyRequest(request : APIRequest) : APIResponse
    +validateRequest(request : APIRequest) : Boolean
    +enforceRateLimit(request : APIRequest) : Boolean
    +fetchAggregatedData(zoneId : String, metric : String) : List
    +buildSuccessResponse(data : List) : APIResponse
    +buildErrorResponse(message : String) : APIResponse
  }

  class PublicAPIEndpoint {
    +receiveRequest(request : APIRequest)
    +returnResponse(response : APIResponse)
  }

  class RateLimiter {
    +checkRateLimit(userId : String) : Boolean
  }

  class AccessControl {
    +authorizeRequest(request : APIRequest) : Boolean
  }

  entity UsageLog {
    +recordRequestMetadata(request : APIRequest)
    +getUserRequestHistory(userId : String) : List
    +recordRateLimitViolation(userId : String)
  }

  class APIRequest {
    -userId : String
    -endpoint : String
    -zoneId : String
    -metric : String
    -timestamp : DateTime
  }

  class APIResponse {
    -statusCode : int
    -message : String
    -data : List
  }

  PublicAPIEndpoint --> APIManagement
  APIManagement     --> RateLimiter
  APIManagement     --> AccessControl
  APIManagement     --> UsageLog
  RateLimiter       --> UsageLog
  AccessControl     --> UsageLog
  PublicAPIEndpoint ..> APIRequest
  PublicAPIEndpoint ..> APIResponse
}

' =============================================================
' CROSS-SUBSYSTEM CONNECTIONS
' =============================================================

ThresholdManagement   -down-|>  IThresholdService
AccountManagement     -right-|> IAccountService
AggregationManagement -up-|>    IAggregationService
AlertsManagement      -left-|>  IAlertsService

' Layout anchors
ThresholdManagement      -[hidden]down-  AlertsManagement
DataValidationManagement -[hidden]right- AggregationManagement
AggregationManagement    -[hidden]right- APIManagement

' MODIFIED — previously pointed directly to DashboardAgent (a
' Presentation component). Now routes through APIFacade so no
' backend subsystem holds a direct reference to a P class.
ShowDataToDashboards -[#red,bold]up-> APIFacade
NotificationService  -[#red,bold]up-> APIFacade

APIManagement -left-> AggregatedEnvironmentalDataDB
PerformAggregations -left-> ValidSensorDataDB

@enduml
