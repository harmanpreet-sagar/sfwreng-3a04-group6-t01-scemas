@startuml ThresholdManagement_ClassDiagram

class HighLevelUI {
  +displayThresholds()
  +displayForm()
  +displayConfirmation()
  +displayError(msg : String)
}

class APIFacade {
  +routeToThresholdMgmt(req : Request)
}

class ThresholdManagement {
  +receiveRequest(action : String)
  +validateInput(data : Map) : Boolean
  +processAction(action : String, data : Map)
}

class CreateThreshold {
  +inputThresholdData() : Map
  +validateData(data : Map) : Boolean
  +createThreshold(data : Map) : Threshold
  +saveThreshold(t : Threshold)
}

class EditThreshold {
  +loadThreshold(id : int) : Threshold
  +editThreshold(t : Threshold, changes : Map)
  +validateChanges(changes : Map) : Boolean
  +saveThreshold(t : Threshold)
}

class DeleteThreshold {
  +receiveDeleteRequest(id : int)
  +retrieveThreshold(id : int) : Threshold
  +deleteThreshold(t : Threshold)
  +updateRepository(id : int)
}

interface IThresholdRepository {
  +save(t : Threshold)
  +update(t : Threshold)
  +delete(id : int)
  +findById(id : int) : Threshold
  +findAll() : List<Threshold>
  +findActive() : List<Threshold>
}

entity ThresholdDB {
  +save(t : Threshold)
  +update(t : Threshold)
  +delete(id : int)
  +findById(id : int) : Threshold
  +findAll() : List<Threshold>
  +findActive() : List<Threshold>
}

entity Threshold {
  -id : int
  -metricType : String
  -zone : String
  -condition : String
  -severityLevel : String
  -isActive : Boolean
  -createdAt : DateTime
  -updatedAt : DateTime
  +activate()
  +deactivate()
  +getDetails() : Map
}

class AlertsManagement {
}

HighLevelUI --> ThresholdManagement : uses
APIFacade --> ThresholdManagement : routes to
ThresholdManagement --> CreateThreshold : delegates
ThresholdManagement --> EditThreshold : delegates
ThresholdManagement --> DeleteThreshold : delegates
CreateThreshold ..> IThresholdRepository : uses
EditThreshold ..> IThresholdRepository : uses
DeleteThreshold ..> IThresholdRepository : uses
ThresholdDB ..|> IThresholdRepository : implements
ThresholdDB *-- Threshold : stores
ThresholdDB --> AlertsManagement : supplies thresholds to

@enduml