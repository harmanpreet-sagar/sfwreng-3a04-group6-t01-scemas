@startuml PresentationLayer_ClassDiagram
title Presentation Layer

' ─── Own shared types ───────────────────────────────────────
class Request {
  -endpoint : String
  -userId : String
  -role : String
  -payload : Map
  -timestamp : DateTime
  -apiKey : String
}

class Result {
  -success : Boolean
  -data : Map
  -errorMessage : String
  -statusCode : int
  -timestamp : DateTime
}

class Response {
  -statusCode : int
  -body : Map
  -message : String
  -timestamp : DateTime
}

class successResponse {
  -result : Result
  -resp : Response
  +formatAndReturnSuccessResponse()
}

class errorResponse {
  -statusCode : int
  -resp : Response
  +formatAndReturnErrorResponse()
}

entity Alert {
  -alertId : String
  -severity : String
  -status : String
  -zone : String
  -metric : String
}

' ─── Own classes ────────────────────────────────────────────
class AccountAdminAgent <<Presentation>> {
  +initiateAccountOperation(req : Request)
}

class ThresholdAdminAgent <<Presentation>> {
  +initiateThresholdOperation(req : Request)
}

class DashboardAgent <<Presentation>> {
  +displayData(data : Map)
  +displayAlert(alert : Alert)
  +displayAlerts()
  +refreshView()
}

' NEW — was missing from original diagram despite being in the D2
' architecture diagram as "Recent Activity Cache". Completes the PAC
' Abstraction (A) component. Holds UI-visible state so no Presentation
' class ever queries a backend subsystem directly.
class RecentActivityCache <<Abstraction>> #FFD0D0 {
  -cachedAlerts : List
  -cachedThresholds : List
  -lastUpdated : DateTime
  +getAlerts() : List
  +getThresholds() : List
  +updateAlerts(alerts : List)
  +updateThresholds(thresholds : List)
  +invalidate()
}

class APIFacade <<Control>> {
  -req : Request
  -result : Result
  -resp : Response
  +apiRequest(req : Request)
  +validateRequest(req : Request) : Boolean
  +authorizeRequest(req : Request) : Boolean
  +dispatchRequest(req : Request) : Result
  +formatResponse(result : Result) : Response
  +returnResponse(resp : Response)
}

interface IThresholdService {
  +receiveRequest(action : String)
  +validateInput(data : Map) : Boolean
  +processAction(action : String, data : Map)
}

interface IAccountService {
  +login(credentials : Map) : Boolean
  +changeCredentials(data : Map)
  +deactivateAccount(id : int)
}

' MODIFIED — evaluateTelemetry() removed: this method no longer exists
' on AlertsManagement (it was moved to ThresholdEvaluatorWorker).
interface IAlertsService ##[bold]red {
  +generateAlert(violation : Map) : Alert
  +updateAlertStatus(id : int, status : String)
}

interface IAggregationService {
  +performAggregations()
  +showDataToDashboards(data : Map)
}

' ─── External stubs (implemented in other subsystems) ───────
class AccountManagement <<external>> {
}

class ThresholdManagement <<external>> {
}

class AlertsManagement <<external>> {
}

class AggregationManagement <<external>> {
}

class ShowDataToDashboards <<external>> {
}

class NotificationService <<external>> {
}

' ─── Internal relationships ──────────────────────────────────
AccountAdminAgent   --> APIFacade
ThresholdAdminAgent --> APIFacade
DashboardAgent      --> APIFacade

' NEW — completing the PAC C<->A and A->P wiring
APIFacade           -[#red,bold]-> RecentActivityCache
RecentActivityCache -[#red,bold]-> DashboardAgent

APIFacade --> IThresholdService
APIFacade --> IAccountService
APIFacade --> IAlertsService
APIFacade --> IAggregationService

APIFacade          ..> Request
APIFacade          ..> Result
APIFacade          ..> Response
APIFacade          ..> successResponse
APIFacade          ..> errorResponse
AccountAdminAgent  ..> Request
ThresholdAdminAgent ..> Request
DashboardAgent     ..> Alert
IAlertsService     ..> Alert
RecentActivityCache ..> Alert
successResponse    ..> Result
successResponse    ..> Response
errorResponse      ..> Response

' ─── Cross-subsystem connections ─────────────────────────────
AccountManagement     ..|> IAccountService
ThresholdManagement   ..|> IThresholdService
AlertsManagement      ..|> IAlertsService
AggregationManagement ..|> IAggregationService

' MODIFIED — ShowDataToDashboards and NotificationService previously
' pointed directly to DashboardAgent (a Presentation component).
' Both now route through APIFacade (the PAC Control) so no backend
' subsystem holds a direct reference to a Presentation class.
ShowDataToDashboards  -[#red,bold]-> APIFacade
NotificationService   -[#red,bold]-> APIFacade

@enduml
