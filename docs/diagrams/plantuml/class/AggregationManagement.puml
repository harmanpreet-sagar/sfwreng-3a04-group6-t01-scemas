@startuml AggregationManagement_ClassDiagram

' =========================
' BOUNDARY
' =========================
class DashboardAgent {
  +displayData(data : Map)
  +displayAlert(alert : Alert)
}

' =========================
' API FACADE
' =========================
class APIFacade {
  -req : Request
  -result : Result
  -resp : Response
  +apiRequest(req : Request)
  +validateRequest(req : Request) : Boolean
  +authorizeRequest(req : Request) : Boolean
  +dispatchRequest(req : Request) : Result
  +formatResponse(result : Result) : Response
  +returnResponse(resp : Response)
}

' =========================
' SERVICE INTERFACE
' =========================
interface IAggregationService {
  -data : Map
  +performAggregations()
  +showDataToDashboards(data : Map)
}

' =========================
' AGGREGATION MANAGEMENT
' =========================
class AggregationManagement {
  -data : Map
  +performAggregations()
  +showDataToDashboards(data : Map)
}

class PerformAggregations {
  -zone : String
  -interval : String
  -metricType : String
  +computeAggregatedMetrics(data : Map) : AggregatedData
  +saveResult(d : AggregatedData)
}

class ShowDataToDashboards {
  -zone : String
  +fetchAggregatedData(zone : String) : List
  +sendDataToDashboard(data : Map)
}

' =========================
' REPOSITORY INTERFACE
' =========================
interface IAggregatedDataRepository {
  +save(d : AggregatedData)
  +findByZone(zone : String) : List
  +findByInterval(interval : String) : List
  +findLatest(zone : String) : AggregatedData
}

' =========================
' DB ENTITY
' =========================
entity AggregatedEnvironmentalDataDB {
  -aggregatedData : AggregatedData
  +save(d : AggregatedData)
  +findByZone(zone : String) : List
  +findByInterval(interval : String) : List
  +findLatest(zone : String) : AggregatedData
}

entity AggregatedData {
  -id : int
  -zone : String
  -metricType : String
  -value : double
  -interval : String
  -timestamp : DateTime
  +getSummary() : Map
}

' =========================
' EXTERNAL CONSUMERS
' (owned elsewhere, directly read AggregatedEnvironmentalDataDB)
' =========================
class AlertsManagement {
  -data : Map
  -violation : Map
  +evaluateTelemetry(data : Map)
  +generateAlert(violation : Map) : Alert
  +updateAlertStatus(id : int, status : String)
}

class APIManagement {
  +handleRequest()
  +validateRequest()
  +rateLimitRequest()
  +returnAggregatedData()
}

' External DB this subsystem reads from (owned by Data Validation)
entity ValidSensorDataDB

' =========================
' RELATIONSHIPS
' =========================

' Boundary triggers APIFacade
DashboardAgent --> APIFacade

' APIFacade routes through service interface
APIFacade --> IAggregationService

' AggregationManagement implements service interface
AggregationManagement ..|> IAggregationService

' AggregationManagement delegates to sub-controllers
AggregationManagement --> PerformAggregations
AggregationManagement --> ShowDataToDashboards

' Sub-controllers depend on repository interface
PerformAggregations ..> IAggregatedDataRepository
ShowDataToDashboards ..> IAggregatedDataRepository

' PerformAggregations reads raw validated data from external DB
PerformAggregations --> ValidSensorDataDB

' ShowDataToDashboards pushes results to Dashboard Agent
ShowDataToDashboards --> DashboardAgent

' AggregatedEnvironmentalDataDB implements repository interface
AggregatedEnvironmentalDataDB ..|> IAggregatedDataRepository

' AggregatedEnvironmentalDataDB owns AggregatedData records
AggregatedEnvironmentalDataDB *-- AggregatedData

' Classes that produce or consume AggregatedData as a type
PerformAggregations ..> AggregatedData
IAggregatedDataRepository ..> AggregatedData

' AggregatedEnvironmentalDataDB supplies data to external consumers
AggregatedEnvironmentalDataDB --> AlertsManagement
AggregatedEnvironmentalDataDB --> APIManagement

@enduml
