# Environment Configuration Template
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file with real credentials to version control

# ============================================================================
# Supabase Configuration
# ============================================================================
# Your Supabase project URL (found in project settings)
SUPABASE_URL=

# Direct PostgreSQL connection string for database operations
# Format: postgresql://postgres:[password]@[host]:5432/postgres
SUPABASE_DB_URL= postgresql://postgres.uixybikausshevkqajio:[YOUR-PASSWORD]@aws-1-us-east-2.pooler.supabase.com:5432/postgres

# ============================================================================
# Public API (demo key — used at startup to seed api_keys; not sent to clients by the app)
# ============================================================================
# Plaintext key for demos/tests. Sent later via X-API-Key (or similar) once public routes exist.
# If left empty, the backend uses a fixed dev default; see app/shared/api_key_seed.py.
DEMO_PUBLIC_API_KEY=

# ============================================================================
# Frontend (Vite) — copy into .env next to docker-compose / local dev
# ============================================================================
# Same plaintext as DEMO_PUBLIC_API_KEY so the public landing page can call GET /public/zones
# from the browser (never commit real keys). Optional: map shows coverage only without it.
# VITE_PUBLIC_DEMO_API_KEY=

# ============================================================================
# CORS (backend — e.g. Render)
# ============================================================================
# Comma-separated frontend origins, no trailing slashes. Required for browser calls
# from Vercel to your API when not using "*". Example:
# CORS_ALLOW_ORIGINS=https://your-app.vercel.app,http://localhost:3000
# CORS_ALLOW_ORIGINS=

# ============================================================================
# JWT Authentication
# ============================================================================
# Secret key for signing JWT tokens - use a strong random string
# Generate with: openssl rand -hex 32
JWT_SECRET= SherryTest1234

# ============================================================================
# Twilio SMS Configuration
# ============================================================================
# SMS is OFF unless you set TWILIO_SMS_ENABLED=true (saves trial credits during local demos).
# When enabled and all Twilio vars below are set, new CRITICAL alerts send one SMS to TWILIO_TO_NUMBER.
# Missing Twilio vars: alert is still saved, no SMS.
# TWILIO_SMS_ENABLED=false

# Twilio account identifier from console dashboard (starts with AC)
TWILIO_ACCOUNT_SID=

# Twilio authentication token for API access (rotate if it was ever committed or shared)
TWILIO_AUTH_TOKEN=

# Phone number registered with Twilio (E.164). Optional if you use a Messaging Service.
TWILIO_FROM_NUMBER=

# Optional: Messaging Service SID (MG…) instead of TWILIO_FROM_NUMBER
TWILIO_MESSAGING_SERVICE_SID=

# Demo recipient for CRITICAL alerts (E.164; trial accounts must verify this number in Twilio)
TWILIO_TO_NUMBER=

# ============================================================================
# MQTT Broker Configuration
# ============================================================================
# Hostname of the MQTT broker (use 'mosquitto' for Docker, 'localhost' for local).
# On Render/Fly/etc. use the PUBLIC hostname from your cloud broker (e.g. HiveMQ Cloud).
MQTT_BROKER_HOST=mosquitto

# MQTT broker port (8883 for TLS, 1883 for non-TLS)
MQTT_BROKER_PORT=8883

# Credentials matching src/mosquitto/config/passwd (pre-seeded: admin/admin123).
# To rotate: mosquitto_passwd src/mosquitto/config/passwd <username>
MQTT_USERNAME=admin
MQTT_PASSWORD=admin123

# TLS: set false only if the broker is plain MQTT on 1883 (not typical on the public internet).
# MQTT_USE_TLS=true

# CA for TLS:
# - Local/Docker Mosquitto (self-signed): path to ca.crt (see below).
# - Cloud broker with a public certificate (HiveMQ Cloud, EMQX Cloud, etc.): SYSTEM
MQTT_CA_CERT_PATH=./mosquitto/config/certs/ca.crt
# Render / cloud example (uncomment and set host/user/pass from your broker console):
# MQTT_BROKER_HOST=xxxxxxxx.s1.eu.hivemq.cloud
# MQTT_BROKER_PORT=8883
# MQTT_USERNAME=your-cluster-user
# MQTT_PASSWORD=your-cluster-password
# MQTT_CA_CERT_PATH=SYSTEM
