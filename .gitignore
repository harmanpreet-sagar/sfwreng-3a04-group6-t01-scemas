# ============================================================
# Operating System
# ============================================================
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ============================================================
# IDEs and Editors
# ============================================================
.vscode/
.idea/
*.iml
*.sublime-workspace
*.sublime-project

# ============================================================
# Temporary and log files
# ============================================================
*.tmp
*.bak
*.log

# ============================================================
# Environment / credentials — NEVER COMMIT
# ============================================================
.env
.env.*
*.env
.env.local
.env.production
.env.staging

# ============================================================
# TLS certificates and keys — NEVER COMMIT
# All cert material is generated locally via scripts/generate_certs.sh.
# Committing .crt alongside a gitignored .key causes key/cert mismatch
# when a teammate regenerates the key — which is exactly the failure mode
# we hit on Day 3. Gitignore everything and regenerate locally.
# ============================================================
src/mosquitto/config/certs/*.key
src/mosquitto/config/certs/*.crt
src/mosquitto/config/certs/*.csr
src/mosquitto/config/certs/*.srl
src/mosquitto/config/certs/*.pem

# ============================================================
# MQTT / Mosquitto runtime data — NEVER COMMIT
# ============================================================
src/mosquitto/config/passwd
src/mosquitto/data/
src/mosquitto/log/

# ============================================================
# Node.js
# ============================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv/
*.egg-info/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

