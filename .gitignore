*.log
docker-compose.override.yml

# MQTT/Mosquitto
src/mosquitto/config/passwd
src/mosquitto/data/
src/mosquitto/log/

# TLS Certificates - NEVER commit private keys or certificate signing requests
# Public certificates (.crt) can be committed for development
src/mosquitto/config/certs/*.key
src/mosquitto/config/certs/*.csr
src/mosquitto/config/certs/*.srl

# Frontend build
src/frontend/dist/
src/frontend/.vite/

# Python additional
*.pyc
